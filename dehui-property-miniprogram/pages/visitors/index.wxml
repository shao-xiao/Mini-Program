<view class="page">
  <view class="section card">
    <view class="title">访客预约</view>
    <view class="subtitle">{{identityText || '登录后'}}登记访客并查看到访状态</view>
  </view>

  <view wx:if="{{errorMessage}}" class="card section">
    <view class="empty-title">暂时无法预约访客</view>
    <view class="empty-desc">{{errorMessage}}</view>
    <button class="button-primary bind-button" bindtap="goProfile">去登录或绑定身份</button>
  </view>

  <view wx:if="{{!errorMessage}}" class="section card">
    <view class="section-title">预约信息</view>
    <input class="input" placeholder-class="input-placeholder" placeholder="访客姓名" value="{{form.visitorName}}" data-field="visitorName" bindinput="onInput" />
    <input class="input" placeholder-class="input-placeholder" placeholder="访客手机号" type="number" value="{{form.visitorPhone}}" data-field="visitorPhone" bindinput="onInput" />
    <input class="input" placeholder-class="input-placeholder" placeholder="租户ID，可不填" type="number" value="{{form.tenantId}}" data-field="tenantId" bindinput="onInput" />
    <input class="input" placeholder-class="input-placeholder" placeholder="被访人" value="{{form.visitedPerson}}" data-field="visitedPerson" bindinput="onInput" />
    <input class="input" placeholder-class="input-placeholder" placeholder="来访事由" value="{{form.visitReason}}" data-field="visitReason" bindinput="onInput" />
    <input class="input" placeholder-class="input-placeholder" placeholder="来访时间，如 2026-05-11 14:30" value="{{form.visitTime}}" data-field="visitTime" bindinput="onInput" />
    <input class="input" placeholder-class="input-placeholder" placeholder="车牌号，可不填" value="{{form.carPlateNo}}" data-field="carPlateNo" bindinput="onInput" />
    <textarea class="textarea" placeholder-class="input-placeholder" placeholder="备注，可填写人数、停车需求等" value="{{form.remark}}" data-field="remark" bindinput="onInput" />
    <button class="button-primary submit-button" loading="{{submitting}}" bindtap="submitVisitor">
      提交预约
    </button>
  </view>

  <view wx:if="{{loading}}" class="card muted">正在加载访客预约...</view>

  <view wx:if="{{!errorMessage && !loading && visitors.length === 0}}" class="card muted">
    暂无访客预约
  </view>

  <view wx:if="{{!errorMessage && visitors.length > 0}}" class="section">
    <view class="section-title">我的访客</view>
    <view wx:for="{{visitors}}" wx:key="id" class="visitor-card">
      <view class="visitor-head">
        <view>
          <view class="visitor-title">{{item.visitorName}}</view>
          <view class="visitor-phone">{{item.visitorPhone}}</view>
        </view>
        <view class="status {{item.statusClass}}">{{item.statusText}}</view>
      </view>
      <view class="visitor-meta">被访人：{{item.visitedPerson}}</view>
      <view class="visitor-meta">来访时间：{{item.visitTimeText}}</view>
      <view wx:if="{{item.tenantName}}" class="visitor-meta">拜访租户：{{item.tenantName}}</view>
      <view class="visitor-desc">{{item.visitReason}}</view>
      <view wx:if="{{item.remark}}" class="visitor-remark">{{item.remark}}</view>
      <view wx:if="{{item.leaveTime}}" class="visitor-meta">离场时间：{{item.leaveTimeText}}</view>
      <view wx:if="{{item.cancellable}}" class="visitor-actions">
        <button class="cancel-button" size="mini" data-id="{{item.id}}" bindtap="cancelVisitor">
          取消预约
        </button>
      </view>
    </view>
  </view>
</view>
