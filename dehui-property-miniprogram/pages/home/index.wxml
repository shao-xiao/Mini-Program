<view class="page">
  <view class="section card">
    <view class="brand-title">
      <image class="brand-logo" src="/assets/dehui-logo.png" mode="aspectFit" />
      <view>
        <view class="title">{{overview.title || '德汇创新中心'}}</view>
        <view class="subtitle">{{overview.subtitle || '移动端物业服务入口'}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="card muted">正在加载真实运营数据...</view>
  <view wx:if="{{publicError}}" class="card error-card">{{publicError}}</view>

  <view class="section metric-grid">
    <view class="metric-card">
      <view class="metric-value">{{metrics.announcements.value}}</view>
      <view class="metric-label">已发布公告</view>
      <view class="metric-desc">{{metrics.announcements.desc}}</view>
    </view>
    <view class="metric-card">
      <view class="metric-value">{{metrics.rooms.value}}</view>
      <view class="metric-label">可租房源</view>
      <view class="metric-desc">{{metrics.rooms.desc}}</view>
    </view>
    <view class="metric-card">
      <view class="metric-value">{{metrics.bills.value}}</view>
      <view class="metric-label">我的账单</view>
      <view class="metric-desc">{{metrics.bills.desc}}</view>
    </view>
    <view class="metric-card">
      <view class="metric-value">{{metrics.meetings.value}}</view>
      <view class="metric-label">我的会议</view>
      <view class="metric-desc">{{metrics.meetings.desc}}</view>
    </view>
    <view class="metric-card">
      <view class="metric-value">{{metrics.workorders.value}}</view>
      <view class="metric-label">我的工单</view>
      <view class="metric-desc">{{metrics.workorders.desc}}</view>
    </view>
    <view class="metric-card">
      <view class="metric-value">{{metrics.visitors.value}}</view>
      <view class="metric-label">访客预约</view>
      <view class="metric-desc">{{metrics.visitors.desc}}</view>
    </view>
  </view>

  <view class="section card">
    <view class="section-title">最新公告</view>
    <view wx:if="{{latestAnnouncement}}">
      <view class="announcement-title">{{latestAnnouncement.title}}</view>
      <view class="announcement-time">{{latestAnnouncement.publishTimeText}}</view>
      <button class="plain-button" size="mini" data-url="/pages/announcements/index" bindtap="goPage">查看公告</button>
    </view>
    <view wx:else class="muted">暂无已发布公告</view>
  </view>

  <view class="section grid">
    <navigator class="action" url="/pages/announcements/index">
      <view class="action-title">公告通知</view>
      <view class="action-desc">园区公告与运营提醒</view>
    </navigator>
    <navigator class="action" url="/pages/bills/index">
      <view class="action-title">账单中心</view>
      <view class="action-desc">租金、能耗、停车和服务账单</view>
    </navigator>
    <navigator class="action" url="/pages/meeting/index">
      <view class="action-title">会议预约</view>
      <view class="action-desc">查询会议室并发起预约</view>
    </navigator>
    <navigator class="action" url="/pages/workorders/index">
      <view class="action-title">报修服务</view>
      <view class="action-desc">提交报修并查看进度</view>
    </navigator>
    <navigator class="action" url="/pages/visitors/index">
      <view class="action-title">访客预约</view>
      <view class="action-desc">登记访客并查看到访状态</view>
    </navigator>
    <navigator class="action" url="/pages/investment/index">
      <view class="action-title">招商中心</view>
      <view class="action-desc">查看真实可租房源并预约看房</view>
    </navigator>
    <navigator class="action" url="/pages/checkin/index">
      <view class="action-title">员工签到</view>
      <view class="action-desc">内部员工移动打卡</view>
    </navigator>
    <navigator class="action" url="/pages/me/index">
      <view class="action-title">我的身份</view>
      <view class="action-desc">登录、绑定租户或内部账号</view>
    </navigator>
  </view>
</view>
