.brand-title {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.brand-logo {
  width: 72rpx;
  height: 72rpx;
  flex: none;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.metric-card {
  min-height: 162rpx;
  padding: 24rpx;
  border-radius: 10rpx;
  background: #ffffff;
  box-sizing: border-box;
  box-shadow: 0 8rpx 24rpx rgba(31, 27, 27, 0.06);
}

.metric-value {
  color: #d93025;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.1;
}

.metric-label {
  margin-top: 10rpx;
  color: #1f1b1b;
  font-size: 26rpx;
  font-weight: 600;
}

.metric-desc {
  margin-top: 8rpx;
  color: #909399;
  font-size: 21rpx;
  line-height: 1.35;
}

.section-title {
  margin-bottom: 16rpx;
  color: #1f1b1b;
  font-size: 30rpx;
  font-weight: 700;
}

.announcement-title {
  color: #1f1b1b;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
}

.announcement-time {
  margin-top: 8rpx;
  color: #909399;
  font-size: 24rpx;
}

.plain-button {
  margin-top: 18rpx;
  margin-left: 0;
  background: #d93025;
  color: #ffffff;
  border-radius: 8rpx;
}

.error-card {
  color: #d93025;
  font-size: 26rpx;
  line-height: 1.6;
}
