<view class="page">
  <view class="section card">
    <view class="title">公告通知</view>
    <view class="subtitle">园区公告、活动通知和运营提醒</view>
  </view>

  <view wx:if="{{loading}}" class="card muted">正在加载公告...</view>

  <view wx:elif="{{errorMessage}}" class="card muted">{{errorMessage}}</view>

  <view wx:elif="{{announcements.length === 0}}" class="card muted">
    暂无已发布公告
  </view>

  <view wx:else class="section">
    <view
      wx:for="{{announcements}}"
      wx:key="id"
      class="announcement-card"
      data-id="{{item.id}}"
      bindtap="openDetail"
    >
      <view class="announcement-head">
        <view class="announcement-title">{{item.title}}</view>
        <view class="announcement-type">{{item.typeText}}</view>
      </view>
      <view class="announcement-content">{{item.summary}}</view>
      <view class="announcement-time">{{item.publishTimeText}}</view>
    </view>
  </view>
</view>
