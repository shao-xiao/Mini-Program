.home-page {
  background: #F5F6F8;
}

.intro-card {
  min-height: 150rpx;
  display: flex;
  align-items: center;
}

.brand-row {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.brand-logo-wrap {
  width: 96rpx;
  height: 96rpx;
  flex: none;
  border-radius: 50%;
  background: #FFF1F0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.brand-logo {
  width: 78rpx;
  height: 78rpx;
  flex: none;
}

.intro-text {
  flex: 1;
  min-width: 0;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1F2933;
}

.subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.45;
  color: #8A8F99;
}

.section-title {
  margin-bottom: 18rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #1F2933;
}

.home-swiper {
  width: 100%;
  height: 210rpx;
}

.swiper-item {
  display: block;
  box-sizing: border-box;
}

.banner-item {
  position: relative;
  min-height: 200rpx;
  height: 100%;
  padding: 26rpx 28rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #E4312B 0%, #F45B52 100%);
  color: #FFFFFF;
  overflow: hidden;
  box-sizing: border-box;
}

.banner-content {
  padding-right: 126rpx;
}

.banner-title {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.35;
}

.banner-subtitle {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.45;
  color: rgba(255, 255, 255, 0.94);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.banner-time {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.78);
}

.banner-link {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 24rpx;
  line-height: 48rpx;
  color: #FFFFFF;
}

.module-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
}

.module-item {
  min-height: 164rpx;
  padding: 28rpx 18rpx 22rpx;
  border-radius: 18rpx;
  background: #FFFFFF;
  box-sizing: border-box;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.035);
}

.module-title {
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.2;
  color: #1F2933;
}

.module-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.45;
  color: #8A8F99;
}
