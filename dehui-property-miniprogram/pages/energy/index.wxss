.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.summary-card {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 27, 27, 0.06);
}

.summary-label {
  color: #73767a;
  font-size: 24rpx;
}

.summary-value {
  margin-top: 10rpx;
  color: #1f1b1b;
  font-size: 34rpx;
  font-weight: 700;
}

.summary-desc {
  margin-top: 8rpx;
  color: #a8abb2;
  font-size: 22rpx;
}

.section-title {
  margin-bottom: 16rpx;
  color: #1f1b1b;
  font-size: 30rpx;
  font-weight: 700;
}

.energy-card {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 27, 27, 0.06);
}

.energy-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.energy-title {
  color: #1f1b1b;
  font-size: 30rpx;
  font-weight: 700;
}

.energy-sub {
  margin-top: 6rpx;
  color: #909399;
  font-size: 23rpx;
}

.energy-status {
  flex: none;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #f4f4f5;
  color: #606266;
  font-size: 22rpx;
}

.energy-status.warn {
  background: #fff4e5;
  color: #e67e22;
}

.energy-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 8rpx 0;
  color: #606266;
  font-size: 24rpx;
}

.empty-title {
  color: #1f1b1b;
  font-size: 30rpx;
  font-weight: 700;
}

.empty-desc {
  margin-top: 12rpx;
  color: #73767a;
  font-size: 26rpx;
  line-height: 1.6;
}

.bind-button {
  margin-top: 24rpx;
}
