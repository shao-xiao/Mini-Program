<view class="page">
  <view class="section hero">
    <block wx:if="{{hero}}">
      <view class="hero-title">{{hero.title}}</view>
      <view wx:if="{{hero.subtitle}}" class="hero-subtitle">{{hero.subtitle}}</view>
      <view wx:if="{{hero.content}}" class="hero-address">{{hero.content}}</view>
    </block>
    <block wx:else>
      <view class="hero-title">招商中心</view>
      <view class="hero-subtitle">暂无已发布招商内容</view>
    </block>
  </view>

  <view wx:if="{{loading}}" class="card muted">正在加载招商信息...</view>

  <view wx:if="{{sections.highlight.length}}" class="section card">
    <view class="section-title">园区亮点</view>
    <view class="highlight-grid">
      <view wx:for="{{sections.highlight}}" wx:key="title" class="highlight-item">
        <view class="item-title">{{item.title}}</view>
        <view wx:if="{{item.subtitle}}" class="item-subtitle">{{item.subtitle}}</view>
        <view wx:if="{{item.content}}" class="item-content">{{item.content}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{sections.policy.length}}" class="section card">
    <view class="section-title">招商政策</view>
    <view wx:for="{{sections.policy}}" wx:key="title" class="policy-item">
      <view class="item-title">{{item.title}}</view>
      <view wx:if="{{item.subtitle}}" class="item-subtitle">{{item.subtitle}}</view>
      <view wx:if="{{item.content}}" class="item-content">{{item.content}}</view>
    </view>
  </view>

  <view wx:if="{{sections.introduction.length}}" class="section card">
    <view class="section-title">园区介绍</view>
    <view wx:for="{{sections.introduction}}" wx:key="title" class="text-block">
      <view class="item-title">{{item.title}}</view>
      <view wx:if="{{item.subtitle}}" class="item-subtitle">{{item.subtitle}}</view>
      <view wx:if="{{item.content}}" class="item-content">{{item.content}}</view>
    </view>
  </view>

  <view wx:if="{{sections.location.length}}" class="section card">
    <view class="section-title">园区地址</view>
    <view wx:for="{{sections.location}}" wx:key="title" class="text-block">
      <view class="item-title">{{item.title}}</view>
      <view wx:if="{{item.subtitle}}" class="item-subtitle">{{item.subtitle}}</view>
      <view wx:if="{{item.content}}" class="item-content">{{item.content}}</view>
    </view>
  </view>

  <view wx:if="{{sections.contact.length}}" class="section card">
    <view class="section-title">联系方式</view>
    <view wx:for="{{sections.contact}}" wx:key="title" class="text-block">
      <view class="item-title">{{item.title}}</view>
      <view wx:if="{{item.subtitle}}" class="item-subtitle">{{item.subtitle}}</view>
      <view wx:if="{{item.content}}" class="item-content">{{item.content}}</view>
    </view>
  </view>

  <view wx:if="{{sections.notice.length}}" class="section card">
    <view class="section-title">招商公告</view>
    <view wx:for="{{sections.notice}}" wx:key="title" class="policy-item">
      <view class="item-title">{{item.title}}</view>
      <view wx:if="{{item.subtitle}}" class="item-subtitle">{{item.subtitle}}</view>
      <view wx:if="{{item.content}}" class="item-content">{{item.content}}</view>
    </view>
  </view>

  <view class="section card">
    <view class="section-title">预约看房</view>
    <view class="form-tip">请留下意向面积和使用需求，招商顾问会根据实际房源情况与您联系。</view>
    <input
      class="input"
      placeholder-class="input-placeholder"
      placeholder="联系人"
      value="{{leadForm.name}}"
      data-field="name"
      bindinput="onLeadInput"
    />
    <input
      class="input"
      placeholder-class="input-placeholder"
      placeholder="联系电话"
      type="number"
      value="{{leadForm.phone}}"
      data-field="phone"
      bindinput="onLeadInput"
    />
    <input
      class="input"
      placeholder-class="input-placeholder"
      placeholder="公司名称"
      value="{{leadForm.companyName}}"
      data-field="companyName"
      bindinput="onLeadInput"
    />
    <input
      class="input"
      placeholder-class="input-placeholder"
      placeholder="意向面积，例如 100㎡"
      type="digit"
      value="{{leadForm.desiredArea}}"
      data-field="desiredArea"
      bindinput="onLeadInput"
    />
    <input
      class="input"
      placeholder-class="input-placeholder"
      placeholder="用途，例如 研发办公 / 企业总部"
      value="{{leadForm.intendedUse}}"
      data-field="intendedUse"
      bindinput="onLeadInput"
    />
    <input
      class="input"
      placeholder-class="input-placeholder"
      placeholder="期望看房时间，例如 本周五下午"
      value="{{leadForm.preferredVisitTime}}"
      data-field="preferredVisitTime"
      bindinput="onLeadInput"
    />
    <textarea
      class="textarea"
      placeholder-class="input-placeholder"
      placeholder="补充需求，例如楼层偏好、入驻时间、预算范围"
      value="{{leadForm.remark}}"
      data-field="remark"
      bindinput="onLeadInput"
    />
    <button class="button-primary submit-button" loading="{{submitting}}" bindtap="submitLead">
      提交预约
    </button>
  </view>
</view>
