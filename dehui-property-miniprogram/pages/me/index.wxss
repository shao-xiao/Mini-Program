.input {
  height: 88rpx;
  border: 1rpx solid #dcdfe6;
  border-radius: 8rpx;
  padding: 0 20rpx;
  margin-top: 18rpx;
  box-sizing: border-box;
  background: #fff;
}

button {
  margin-top: 22rpx;
}

.api-status-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 18rpx;
}

.api-status {
  min-width: 112rpx;
  padding: 8rpx 14rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  text-align: center;
  background: #f4f4f5;
  color: #606266;
}

.api-status.success {
  background: #e9f7ef;
  color: #1e8e3e;
}

.api-status.danger {
  background: #fdecea;
  color: #d93025;
}

.api-message {
  flex: 1;
  color: #73767a;
  font-size: 24rpx;
}

.api-actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.api-actions button {
  margin-top: 16rpx;
}

.fixtures-box {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  background: #f5f6f8;
  color: #606266;
  font-size: 24rpx;
  line-height: 1.7;
}
