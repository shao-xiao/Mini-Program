<view class="page">
  <view class="section card">
    <view class="title">我的</view>
    <view class="subtitle">当前身份：{{identityText || '游客'}}</view>
    <view wx:if="{{profile.nickname}}" class="api-message">昵称：{{profile.nickname}}</view>
    <view wx:if="{{profile.boundTenantName}}" class="api-message">绑定租户：{{profile.boundTenantName}}</view>
    <view wx:if="{{profile.boundSysRealName || profile.boundSysUsername}}" class="api-message">内部账号：{{profile.boundSysRealName || profile.boundSysUsername}}</view>
  </view>

  <view class="section card">
    <view class="section-title">接口设置</view>
    <input
      class="input"
      placeholder-class="input-placeholder"
      placeholder="baseURL"
      value="{{apiForm.baseURL}}"
      bindinput="onApiInput"
    />
    <view class="api-status-row">
      <view class="api-status {{apiStatusClass}}">{{apiStatus}}</view>
      <view class="api-message">{{apiMessage}}</view>
    </view>
    <view class="api-actions">
      <button size="mini" bindtap="useDefaultApi">恢复默认</button>
      <button size="mini" bindtap="useLanApi">局域网</button>
      <button size="mini" bindtap="saveApiBaseURL">保存地址</button>
      <button size="mini" class="button-primary" loading="{{checkingApi}}" bindtap="checkBackend">检测后端</button>
    </view>
    <view class="api-message">当前请求地址：{{apiBaseURL}}</view>
  </view>

  <view class="section card">
    <view class="section-title">租户账号绑定</view>
    <input
      class="input"
      placeholder-class="input-placeholder"
      placeholder="手机号码"
      value="{{tenantAccountForm.phone}}"
      data-field="phone"
      bindinput="onTenantAccountInput"
    />
    <input
      class="input"
      placeholder-class="input-placeholder"
      placeholder="密码"
      password="true"
      value="{{tenantAccountForm.password}}"
      data-field="password"
      bindinput="onTenantAccountInput"
    />
    <button class="button-primary" bindtap="bindTenantAccount">微信登录绑定租户</button>
  </view>

  <view class="section card">
    <view class="section-title">内部人员绑定</view>
    <input
      class="input"
      placeholder-class="input-placeholder"
      placeholder="用户名"
      value="{{internalForm.username}}"
      data-field="username"
      bindinput="onInternalInput"
    />
    <input
      class="input"
      placeholder-class="input-placeholder"
      placeholder="密码"
      password="true"
      value="{{internalForm.password}}"
      data-field="password"
      bindinput="onInternalInput"
    />
    <button class="button-primary" bindtap="bindInternal">绑定内部用户</button>
  </view>

  <view class="section card">
    <button size="mini" bindtap="toggleDebugPanel">
      {{showDebugPanel ? '隐藏调试入口' : '显示调试入口'}}
    </button>
    <view wx:if="{{showDebugPanel}}" class="dev-card">
      <view class="section-title">开发调试</view>
      <view class="section-subtitle">仅调试环境可用</view>
      <input
        class="input"
        placeholder-class="input-placeholder"
        placeholder="调试手机号"
        value="{{devForm.phone}}"
        data-field="phone"
        bindinput="onDevInput"
      />
      <input
        class="input"
        placeholder-class="input-placeholder"
        placeholder="昵称（可选）"
        value="{{devForm.nickname}}"
        data-field="nickname"
        bindinput="onDevInput"
      />
      <button bindtap="devLogin">开发登录</button>

      <view wx:if="{{fixtures}}" class="fixtures-box">
        <view class="fixtures-title">服务端调试数据</view>
        <view>tenantId：{{fixtures.testTenantId || '-'}}</view>
        <view>phone：{{fixtures.testPhone || '-'}}</view>
      </view>

      <view class="section-title">租户 ID 直绑（调试）</view>
      <input
        class="input"
        placeholder-class="input-placeholder"
        placeholder="租户ID"
        value="{{tenantForm.tenantId}}"
        data-field="tenantId"
        bindinput="onTenantInput"
      />
      <input
        class="input"
        placeholder-class="input-placeholder"
        placeholder="联系人"
        value="{{tenantForm.name}}"
        data-field="name"
        bindinput="onTenantInput"
      />
      <input
        class="input"
        placeholder-class="input-placeholder"
        placeholder="联系方式"
        value="{{tenantForm.phone}}"
        data-field="phone"
        bindinput="onTenantInput"
      />
      <input
        class="input"
        placeholder-class="input-placeholder"
        placeholder="角色"
        value="{{tenantForm.role}}"
        data-field="role"
        bindinput="onTenantInput"
      />
      <button bindtap="bindTenant">直绑租户</button>
    </view>
  </view>

  <view class="section card">
    <button size="mini" bindtap="logout">退出登录</button>
  </view>
</view>
