.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.summary-card {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 27, 27, 0.06);
}

.summary-label {
  color: #73767a;
  font-size: 24rpx;
}

.summary-value {
  margin-top: 10rpx;
  color: #1f1b1b;
  font-size: 34rpx;
  font-weight: 700;
}

.summary-value.warn {
  color: #e67e22;
}

.summary-desc {
  margin-top: 8rpx;
  color: #a8abb2;
  font-size: 22rpx;
}

.filter-row {
  display: flex;
  gap: 16rpx;
}

.filter-item {
  min-width: 136rpx;
  padding: 16rpx 20rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #606266;
  text-align: center;
  font-size: 26rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 27, 27, 0.05);
}

.filter-item.active {
  background: #d93025;
  color: #ffffff;
}

.bill-card {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 27, 27, 0.06);
}

.bill-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.bill-title {
  color: #1f1b1b;
  font-size: 32rpx;
  font-weight: 700;
}

.bill-number {
  margin-top: 6rpx;
  color: #a8abb2;
  font-size: 22rpx;
}

.bill-status {
  flex: none;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.bill-status.paid {
  background: #e8f5e9;
  color: #2e7d32;
}

.bill-status.unpaid {
  background: #fdecea;
  color: #d93025;
}

.bill-status.overdue {
  background: #fff4e5;
  color: #e67e22;
}

.bill-money {
  margin-top: 24rpx;
  color: #d93025;
  font-size: 42rpx;
  font-weight: 800;
}

.bill-meta {
  margin-top: 10rpx;
  color: #606266;
  font-size: 24rpx;
}

.bill-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #ebeef5;
}

.bill-paid {
  color: #909399;
  font-size: 24rpx;
}

.pay-button {
  margin: 0;
  background: #d93025;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 24rpx;
}
