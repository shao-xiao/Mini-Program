<view class="page">
  <view class="section card">
    <view class="title">报修服务</view>
    <view class="subtitle">{{identityText || '登录后'}}提交报修并查看处理进度</view>
  </view>

  <view wx:if="{{errorMessage}}" class="card section">
    <view class="empty-title">暂时无法提交报修</view>
    <view class="empty-desc">{{errorMessage}}</view>
    <button class="button-primary bind-button" bindtap="goProfile">去登录或绑定身份</button>
  </view>

  <view wx:if="{{!errorMessage}}" class="section card">
    <view class="section-title">报修信息</view>
    <input
      class="input"
      placeholder-class="input-placeholder"
      placeholder="报修标题，如 空调不制冷"
      value="{{form.title}}"
      data-field="title"
      bindinput="onInput"
    />
    <input
      class="input"
      placeholder-class="input-placeholder"
      placeholder="报修位置，如 B座 205"
      value="{{form.location}}"
      data-field="location"
      bindinput="onInput"
    />
    <input
      class="input"
      placeholder-class="input-placeholder"
      placeholder="联系电话"
      value="{{form.contactPhone}}"
      data-field="contactPhone"
      bindinput="onInput"
    />

    <view class="field-title">报修类别</view>
    <view class="chip-row">
      <view
        wx:for="{{categories}}"
        wx:key="value"
        class="chip {{form.category === item.value ? 'active' : ''}}"
        data-value="{{item.value}}"
        bindtap="selectCategory"
      >
        {{item.label}}
      </view>
    </view>

    <view class="field-title">紧急程度</view>
    <view class="chip-row">
      <view
        wx:for="{{priorities}}"
        wx:key="value"
        class="chip {{form.priority === item.value ? 'active' : ''}}"
        data-value="{{item.value}}"
        bindtap="selectPriority"
      >
        {{item.label}}
      </view>
    </view>

    <textarea
      class="textarea"
      placeholder-class="input-placeholder"
      placeholder="请描述问题现象、影响范围或方便上门时间"
      value="{{form.description}}"
      data-field="description"
      bindinput="onInput"
    />
    <button class="button-primary submit-button" loading="{{submitting}}" bindtap="submitWorkOrder">
      提交报修
    </button>
  </view>

  <view wx:if="{{loading}}" class="card muted">正在加载报修记录...</view>

  <view wx:if="{{!errorMessage && !loading && workOrders.length === 0}}" class="card muted">
    暂无报修记录
  </view>

  <view wx:if="{{!errorMessage && workOrders.length > 0}}" class="section">
    <view class="section-title">我的报修</view>
    <view wx:for="{{workOrders}}" wx:key="id" class="workorder-card">
      <view class="workorder-head">
        <view>
          <view class="workorder-title">{{item.title}}</view>
          <view class="workorder-number">{{item.orderNumber}}</view>
        </view>
        <view class="status {{item.statusClass}}">{{item.statusText}}</view>
      </view>
      <view class="workorder-meta">{{item.categoryText}} · {{item.priorityText}}</view>
      <view class="workorder-meta">位置：{{item.location}}</view>
      <view class="workorder-desc">{{item.description}}</view>
      <view class="workorder-time">{{item.createdTimeText}}</view>
      <view class="timeline">
        <view
          wx:for="{{item.timeline}}"
          wx:key="label"
          wx:for-item="step"
          class="timeline-item {{step.active ? 'active' : ''}}"
        >
          <view class="timeline-dot"></view>
          <view class="timeline-body">
            <view class="timeline-label">{{step.label}}</view>
            <view class="timeline-time">{{step.timeText || '待更新'}}</view>
          </view>
        </view>
      </view>
      <view wx:if="{{item.cancellable}}" class="workorder-actions">
        <button
          class="cancel-button"
          size="mini"
          data-id="{{item.id}}"
          bindtap="cancelWorkOrder"
        >
          撤回报修
        </button>
      </view>
    </view>
  </view>
</view>
