.section-title {
  margin: 4rpx 0 16rpx;
  color: #1f1b1b;
  font-size: 30rpx;
  font-weight: 700;
}

.input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  margin-top: 18rpx;
  padding: 0 18rpx;
  border-radius: 8rpx;
  background: #f5f6f8;
  color: #1f1b1b;
  font-size: 26rpx;
}

.input {
  height: 72rpx;
  line-height: 72rpx;
}

.textarea {
  min-height: 170rpx;
  padding-top: 18rpx;
  padding-bottom: 18rpx;
  line-height: 38rpx;
}

.input-placeholder {
  color: #a8abb2;
  font-size: 26rpx;
  line-height: 72rpx;
}

.field-title {
  margin-top: 24rpx;
  color: #606266;
  font-size: 25rpx;
  font-weight: 600;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 14rpx;
}

.chip {
  min-width: 112rpx;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: #f5f6f8;
  color: #606266;
  text-align: center;
  font-size: 24rpx;
}

.chip.active {
  background: #d93025;
  color: #ffffff;
}

.submit-button,
.bind-button {
  margin-top: 24rpx;
}

.workorder-card {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 27, 27, 0.06);
}

.workorder-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.workorder-title {
  color: #1f1b1b;
  font-size: 32rpx;
  font-weight: 700;
}

.workorder-number,
.workorder-time {
  margin-top: 8rpx;
  color: #a8abb2;
  font-size: 23rpx;
}

.status {
  flex: none;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.status.created {
  background: #fdecea;
  color: #d93025;
}

.status.processing {
  background: #fff4e5;
  color: #e67e22;
}

.status.done {
  background: #e8f5e9;
  color: #2e7d32;
}

.status.cancelled {
  background: #ebeef5;
  color: #909399;
}

.workorder-meta {
  margin-top: 12rpx;
  color: #606266;
  font-size: 24rpx;
}

.workorder-desc {
  margin-top: 14rpx;
  color: #303133;
  font-size: 26rpx;
  line-height: 1.6;
}

.timeline {
  margin-top: 22rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #ebeef5;
}

.timeline-item {
  display: flex;
  gap: 14rpx;
  padding-bottom: 16rpx;
  color: #a8abb2;
}

.timeline-dot {
  width: 14rpx;
  height: 14rpx;
  margin-top: 8rpx;
  border-radius: 50%;
  background: #c0c4cc;
  flex: none;
}

.timeline-item.active .timeline-dot {
  background: #d93025;
}

.timeline-body {
  min-width: 0;
}

.timeline-label {
  color: #606266;
  font-size: 24rpx;
  font-weight: 600;
}

.timeline-item.active .timeline-label {
  color: #1f1b1b;
}

.timeline-time {
  margin-top: 4rpx;
  color: #a8abb2;
  font-size: 22rpx;
}

.workorder-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
}

.image-grid,
.uploaded-images {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 14rpx;
}

.image-item,
.image-add,
.uploaded-thumb {
  width: 144rpx;
  height: 144rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.image-item {
  position: relative;
}

.image-thumb,
.uploaded-thumb {
  width: 144rpx;
  height: 144rpx;
  background: #f5f6f8;
}

.image-remove {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.55);
  color: #ffffff;
  text-align: center;
  line-height: 34rpx;
  font-size: 26rpx;
}

.image-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx dashed #c0c4cc;
  color: #909399;
  background: #f5f6f8;
}

.image-add-icon {
  font-size: 44rpx;
  line-height: 1;
}

.image-add-text {
  margin-top: 8rpx;
  font-size: 22rpx;
}

.cancel-button {
  margin: 0;
  border-radius: 8rpx;
  background: #ffffff;
  color: #d93025;
  border: 1rpx solid #d93025;
  font-size: 24rpx;
}

.empty-title {
  color: #1f1b1b;
  font-size: 30rpx;
  font-weight: 700;
}

.empty-desc {
  margin-top: 12rpx;
  color: #73767a;
  font-size: 26rpx;
  line-height: 1.6;
}
