.section-title {
  margin: 4rpx 0 16rpx;
  color: #1f1b1b;
  font-size: 30rpx;
  font-weight: 700;
}

.input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  margin-top: 18rpx;
  padding: 0 18rpx;
  border-radius: 8rpx;
  background: #f5f6f8;
  color: #1f1b1b;
  font-size: 26rpx;
}

.input {
  height: 72rpx;
  line-height: 72rpx;
}

.textarea {
  min-height: 170rpx;
  padding-top: 18rpx;
  padding-bottom: 18rpx;
  line-height: 38rpx;
}

.input-placeholder {
  color: #a8abb2;
  font-size: 26rpx;
  line-height: 72rpx;
}

.field-title {
  margin-top: 24rpx;
  color: #606266;
  font-size: 25rpx;
  font-weight: 600;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 14rpx;
}

.chip {
  min-width: 112rpx;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: #f5f6f8;
  color: #606266;
  text-align: center;
  font-size: 24rpx;
}

.chip.active {
  background: #d93025;
  color: #ffffff;
}

.submit-button,
.bind-button {
  margin-top: 24rpx;
}

.workorder-card {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 27, 27, 0.06);
}

.workorder-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.workorder-title {
  color: #1f1b1b;
  font-size: 32rpx;
  font-weight: 700;
}

.workorder-number,
.workorder-time {
  margin-top: 8rpx;
  color: #a8abb2;
  font-size: 23rpx;
}

.status {
  flex: none;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.status.created {
  background: #fdecea;
  color: #d93025;
}

.status.processing {
  background: #fff4e5;
  color: #e67e22;
}

.status.done {
  background: #e8f5e9;
  color: #2e7d32;
}

.workorder-meta {
  margin-top: 12rpx;
  color: #606266;
  font-size: 24rpx;
}

.workorder-desc {
  margin-top: 14rpx;
  color: #303133;
  font-size: 26rpx;
  line-height: 1.6;
}

.empty-title {
  color: #1f1b1b;
  font-size: 30rpx;
  font-weight: 700;
}

.empty-desc {
  margin-top: 12rpx;
  color: #73767a;
  font-size: 26rpx;
  line-height: 1.6;
}
