page {
  background: #f5f6f8;
  color: #1f1b1b;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.section {
  margin-bottom: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 27, 27, 0.06);
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f1b1b;
}

.subtitle {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #73767a;
}

.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.action {
  min-height: 128rpx;
  border-radius: 10rpx;
  background: #ffffff;
  padding: 24rpx;
  box-sizing: border-box;
}

.action-title {
  font-size: 30rpx;
  font-weight: 600;
}

.action-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #909399;
}

.primary {
  color: #d93025;
}

.muted {
  color: #909399;
}

.button-primary {
  background: #d93025;
  color: #ffffff;
  border-radius: 8rpx;
}
